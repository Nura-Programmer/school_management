generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model School {
  @@map("schools")
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(191)
  address   String    @db.VarChar(255)
  createdAt DateTime  @default(now())
  teachers  Teacher[]
  classes   ClassModel[]
}

model Teacher {
@@map("teachers")
  id        Int      @id @default(autoincrement())
  firstName String   @db.VarChar(100)
  surname   String   @db.VarChar(100)
  schoolId  Int
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([firstName, surname, schoolId])
}

model ClassModel {
  @@map("classes")
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(100)
  schoolId Int
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject[]

  @@unique([name, schoolId])
}

model Subject {
  @@map("subjects")
  id Int @id @default(autoincrement())
  name String @db.VarChar(100)
  classId Int
  class ClassModel @relation(fields: [classId], references: [id], onDelete: Cascade)
}