generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model School {
  id        Int          @id @default(autoincrement())
  name      String       @unique @db.VarChar(191)
  code      String       @unique @db.VarChar(8)
  town      String       @db.VarChar(50)
  address   String       @db.VarChar(255)
  createdAt DateTime     @default(now())
  teachers  Teacher[]
  classes   ClassModel[]
  students  Student[]

  @@map("schools")
}

model Teacher {
  id        Int      @id @default(autoincrement())
  firstName String   @db.VarChar(100)
  surname   String   @db.VarChar(100)
  username  String   @unique @db.VarChar(40) // Auto generate E.g. username@schoolCode.town
  password  String   @db.VarChar(255)
  schoolId  Int
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([username, schoolId])
  @@map("teachers")
}

model ClassModel {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(100)
  schoolId Int
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjects Subject[]
  students Student[]

  @@unique([name, schoolId])
  @@map("classes")
}

model Subject {
  id      Int        @id @default(autoincrement())
  name    String     @db.VarChar(100)
  classId Int
  class   ClassModel @relation(fields: [classId], references: [id], onDelete: Cascade)
  marks   Mark[]

  @@unique([name, classId])
  @@map("subjects")
}

model Student {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(100)
  classType String     @db.VarChar(1)
  classId   Int
  schoolId  Int
  class     ClassModel @relation(fields: [classId], references: [id], onDelete: Cascade)
  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  marks     Mark[]

  @@unique([name, classType, classId, schoolId])
  @@map("students")
}

model Mark {
  id        Int @id @default(autoincrement())
  ca        Int
  test      Int
  exam      Int
  studentId Int
  subjectId Int

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@map("marks")
}
